---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import { getCollection } from "astro:content";
import { t } from "@/i18n/utils";

const locale = "ko";
const pubs = await getCollection("publicationsKo");
const sorted = pubs.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="이력서" locale={locale} currentPath="/ko/cv">
  <div class="max-w-5xl mx-auto px-6 md:px-8 py-16">
    <div class="mb-12 reveal">
      <h1 class="text-4xl font-bold text-[var(--text)] mb-2">이서영</h1>
      <p class="text-[var(--accent)] font-medium mb-1">{t("hero.title", locale)}</p>
      <p class="text-[var(--text-muted)] text-sm">서울, 대한민국 · <a href="mailto:seoyoung.john@gmail.com" class="hover:text-[var(--accent)]">seoyoung.john@gmail.com</a></p>
      <div class="flex gap-3 mt-4">
        <a href="/cv/CV_SeoyoungLee.pdf" download class="px-4 py-2 rounded-lg bg-[var(--accent)] text-white text-sm font-medium hover:bg-[var(--accent-hover)] transition-colors flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          {t("cv.download_en", locale)}
        </a>
        <span class="px-4 py-2 rounded-lg border border-[var(--border)] text-sm font-medium flex items-center gap-2 opacity-40 cursor-not-allowed select-none" title="한국어 CV 준비 중">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          {t("cv.download_ko", locale)}
        </span>
      </div>
    </div>

    <div class="grid md:grid-cols-[2fr_1fr] gap-12">
      <div class="space-y-12">
        <section class="reveal">
          <SectionHeading title={t("cv.education", locale)} />
          <div class="space-y-6">
            <div class="border-l-2 border-[var(--accent)] pl-5">
              <p class="font-semibold text-[var(--text)]">인공지능 석사</p>
              <p class="text-[var(--accent)] text-sm">광주과학기술원(GIST)</p>
              <p class="text-[var(--text-muted)] text-sm">2023.08 – 2025.07 · GPA 4.20 / 4.50</p>
              <p class="text-[var(--text-muted)] text-sm mt-1">지도교수: 김경중 교수</p>
              <p class="text-[var(--text-muted)] text-sm">학위논문: 대조적 언어-상태 임베딩을 활용한 강화학습 기반 인간 유사 절차적 레벨 생성</p>
            </div>
            <div class="border-l-2 border-[var(--border)] pl-5">
              <p class="font-semibold text-[var(--text)]">컴퓨터공학 학사</p>
              <p class="text-[var(--text-muted)] text-sm">동국대학교</p>
              <p class="text-[var(--text-muted)] text-sm">2017.03 – 2023.02 · GPA 3.96 / 4.50</p>
            </div>
          </div>
        </section>

        <section class="reveal">
          <SectionHeading title={t("cv.publications", locale)} />
          <ol class="space-y-4 list-none">
            {sorted.map((pub, i) => (
              <li class="flex gap-3 text-sm">
                <span class="text-[var(--text-muted)] shrink-0 w-5 text-right">[{sorted.length - i}]</span>
                <div>
                  <span class="font-medium text-[var(--text)]">{pub.data.title}</span><br/>
                  <span class="text-[var(--text-muted)]">
                    {pub.data.authors.map((author, ai) => {
                      const hasAsterisk = author.endsWith("*");
                      const name = author.replace(/\*/g, "");
                      const isSY = ["Seo-Young Lee", "Seoyoung Lee"].some(v => name === v);
                      return (
                        <>
                          {isSY ? <strong class="font-semibold text-[var(--text)]">{name}</strong> : name}
                          {hasAsterisk && <sup class="text-[var(--accent)]">*</sup>}
                          {ai < pub.data.authors.length - 1 && ", "}
                        </>
                      );
                    })}
                  </span><br/>
                  <span class="text-[var(--accent)] text-xs">{pub.data.venue} ({pub.data.year})</span>
                  {pub.data.status !== "published" && <span class="text-xs text-amber-400 ml-2">· {pub.data.status === "under_review" ? "심사 중" : "프리프린트"}</span>}
                </div>
              </li>
            ))}
          </ol>
        </section>
      </div>

      <div class="space-y-10">
        <section class="reveal">
          <SectionHeading title={t("cv.skills", locale)} />
          <div class="space-y-4 text-sm">
            <div>
              <p class="text-xs text-[var(--text-muted)] uppercase tracking-wider mb-2">프로그래밍 언어</p>
              <div class="flex flex-wrap gap-1.5">{["Python", "C++"].map((s) => (<span class="px-2.5 py-1 rounded-md bg-[var(--surface)] border border-[var(--border)] text-[var(--text-muted)]">{s}</span>))}</div>
            </div>
            <div>
              <p class="text-xs text-[var(--text-muted)] uppercase tracking-wider mb-2">ML / DL</p>
              <div class="flex flex-wrap gap-1.5">{["PyTorch", "JAX", "Flax"].map((s) => (<span class="px-2.5 py-1 rounded-md bg-[var(--surface)] border border-[var(--border)] text-[var(--text-muted)]">{s}</span>))}</div>
            </div>
            <div>
              <p class="text-xs text-[var(--text-muted)] uppercase tracking-wider mb-2">도구</p>
              <div class="flex flex-wrap gap-1.5">{["Unity", "Git", "Docker"].map((s) => (<span class="px-2.5 py-1 rounded-md bg-[var(--surface)] border border-[var(--border)] text-[var(--text-muted)]">{s}</span>))}</div>
            </div>
          </div>
        </section>
        <section class="reveal">
          <SectionHeading title={t("cv.awards", locale)} />
          <div class="space-y-4 text-sm">
            <div>
              <p class="font-medium text-[var(--text)]">NRF 석사과정생 연구장려금 (PI)</p>
              <p class="text-[var(--text-muted)]">₩12,000,000 · 2024</p>
            </div>
            <div>
              <p class="font-medium text-[var(--text)]">동국 인재육성장학(우수)</p>
              <p class="text-[var(--text-muted)]">2022</p>
            </div>
            <div>
              <p class="font-medium text-[var(--text)]">정보처리산업기사</p>
              <p class="text-[var(--text-muted)]">2020.08</p>
            </div>
          </div>
        </section>
      </div>
    </div>
  </div>
</BaseLayout>
