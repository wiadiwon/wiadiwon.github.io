---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="404 — Page Not Found" currentPath="/404">
  <div class="max-w-5xl mx-auto px-6 md:px-8 py-32 text-center">
    <p class="text-8xl font-bold text-[var(--accent)] mb-4">404</p>
    <h1 class="text-2xl font-bold text-[var(--text)] mb-3">Page Not Found</h1>
    <p class="text-[var(--text-muted)] mb-8">The page you're looking for doesn't exist.</p>
    <a href="/" class="px-6 py-3 rounded-lg bg-[var(--accent)] text-white font-medium hover:bg-[var(--accent-hover)] transition-colors">
      ← Back to Home
    </a>
  </div>
</BaseLayout>
