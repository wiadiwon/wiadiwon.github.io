---
interface Props {
  title: string;
  subtitle?: string;
  align?: "left" | "center";
}

const { title, subtitle, align = "left" } = Astro.props;
---

<div class={`mb-10 ${align === "center" ? "text-center" : ""}`}>
  <h2 class="text-3xl font-bold text-[var(--text)] tracking-tight">
    {title}
    <span class="inline-block w-2 h-2 rounded-full bg-[var(--accent)] ml-1 mb-1"></span>
  </h2>
  {subtitle && (
    <p class="mt-2 text-[var(--text-muted)]">{subtitle}</p>
  )}
</div>
